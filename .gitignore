.env
.env.local
.env.*.local
.env.development
.env.qa

# ───────────────────────────────────────────────────────────────
# Logs
# ───────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ───────────────────────────────────────────────────────────────
# Editor / IDE
# ───────────────────────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.local

# ───────────────────────────────────────────────────────────────
