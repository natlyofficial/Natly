# ───────────────────────────────────────────────────────────────
# Dependencies
# ───────────────────────────────────────────────────────────────
node_modules/

# ───────────────────────────────────────────────────────────────
# Build Output
# ───────────────────────────────────────────────────────────────
dist/
dist-ssr/
.netlify/

# ───────────────────────────────────────────────────────────────
# Testing & Coverage
# ───────────────────────────────────────────────────────────────
coverage/

# ───────────────────────────────────────────────────────────────
# Environment Variables
# ───────────────────────────────────────────────────────────────
